{
  "extends": "../../tsconfig.base.json",
  "include": ["src", "dev-only.d.ts", "./package.json"],
  "exclude": ["dist"],
  "compilerOptions": {
    "rootDir": "./src",
    "allowJs": true,
    "declarationDir": "./dist",
    "outDir": "./dist",
    "jsx": "preserve",
    "composite": true,
    "tsBuildInfoFile": "dist/_cache/.tsbuildinfo",
    "erasableSyntaxOnly": true
  }
}
